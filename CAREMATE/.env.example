# Copy this file to `.env` and fill in values.
# Never commit `.env` (it is gitignored).

# AI analysis (summary + reminders)
# Recommended clean setup for your case:
CARE_LLM_PROVIDER=gemini
CARE_LLM_BASE_URL=
CARE_LLM_API_KEY=
CARE_LLM_MODEL=gemini-2.5-flash-lite

# AI transcription (optional). If empty, local Whisper is used.
CARE_TRANSCRIBE_PROVIDER=
CARE_TRANSCRIBE_BASE_URL=
CARE_TRANSCRIBE_API_KEY=
CARE_TRANSCRIBE_MODEL=

# Gemini transcription option (set these if you want API-first transcription):
# CARE_TRANSCRIBE_PROVIDER=gemini
# CARE_TRANSCRIBE_API_KEY=YOUR_KEY
# CARE_TRANSCRIBE_MODEL=gemini-2.5-flash-lite

# Free option: use a local OpenAI-compatible server (Ollama).
# 1) Install Ollama, run it, and pull a model (e.g. `ollama pull llama3.1:8b`).
# 2) Then set:
# CARE_LLM_PROVIDER=openai_compat
# CARE_LLM_BASE_URL=http://localhost:11434/v1
# CARE_LLM_API_KEY=
# CARE_LLM_MODEL=llama3.1:8b

# Example OpenAI-compatible transcription provider (if available to your account):
# CARE_TRANSCRIBE_PROVIDER=openai_compat
# CARE_TRANSCRIBE_BASE_URL=https://api.groq.com/openai/v1
# CARE_TRANSCRIBE_API_KEY=YOUR_KEY
# CARE_TRANSCRIBE_MODEL=whisper-large-v3-turbo
